# Copy this file to .env and fill in real values. Never commit .env.
#
# Supabase — get from Project Settings > API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<your-service-role-key>

# Resend — get from resend.com/api-keys
RESEND_API_KEY=re_<your-key>

# Operator dashboard key — generate with: python -c "import secrets; print(secrets.token_hex(24))"
DASHBOARD_API_KEY=<generate-a-random-hex-string>

# Demo controls (set to false for production)
DEMO_MODE=true
RESEND_TEST_MODE=true
